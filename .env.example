# Copy this file to .env.local and paste your OpenRouter API key.
# Get a key at: https://openrouter.ai/keys
#
# This key is read ONLY on the server (in the /api routes) and is never sent
# to the browser, so it is safe to deploy publicly. On Vercel, add the same
# variable under Project Settings -> Environment Variables.
OPENROUTER_API_KEY=
