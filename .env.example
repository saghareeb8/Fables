# Copy this file to .env.local and paste your OpenRouter API key.
# Get a key at: https://openrouter.ai/keys
#
# NOTE: Because this app is frontend-only, the NEXT_PUBLIC_ prefix exposes
# this key in the browser bundle. Use it for local/personal use only — do not
# deploy publicly with a real key.
NEXT_PUBLIC_OPENROUTER_API_KEY=
